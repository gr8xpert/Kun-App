<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Typography Styles for KunWorld App -->

    <!-- Base Text Appearance (required for implicit inheritance) -->
    <style name="TextAppearance.KunWorld" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <!-- Display Styles -->
    <style name="TextAppearance.KunWorld.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">57sp</item>
        <item name="android:lineHeight">64sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.KunWorld.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">45sp</item>
        <item name="android:lineHeight">52sp</item>
    </style>

    <style name="TextAppearance.KunWorld.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">36sp</item>
        <item name="android:lineHeight">44sp</item>
    </style>

    <!-- Headline Styles -->
    <style name="TextAppearance.KunWorld.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:lineHeight">40sp</item>
    </style>

    <style name="TextAppearance.KunWorld.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">36sp</item>
    </style>

    <style name="TextAppearance.KunWorld.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">32sp</item>
    </style>

    <!-- Title Styles -->
    <style name="TextAppearance.KunWorld.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:lineHeight">28sp</item>
    </style>

    <style name="TextAppearance.KunWorld.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.KunWorld.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Body Styles -->
    <style name="TextAppearance.KunWorld.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="TextAppearance.KunWorld.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.KunWorld.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- Label Styles -->
    <style name="TextAppearance.KunWorld.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.KunWorld.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.KunWorld.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Custom App-Specific Text Styles -->

    <!-- Section Header (e.g., "Featured Courses") -->
    <style name="TextAppearance.KunWorld.SectionHeader">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Section Header with Accent -->
    <style name="TextAppearance.KunWorld.SectionHeaderAccent">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">28sp</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Card Title -->
    <style name="TextAppearance.KunWorld.CardTitle">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Card Title Large -->
    <style name="TextAppearance.KunWorld.CardTitleLarge">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Card Title on Dark -->
    <style name="TextAppearance.KunWorld.CardTitleOnDark">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Card Subtitle -->
    <style name="TextAppearance.KunWorld.CardSubtitle">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineHeight">18sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Card Subtitle on Dark -->
    <style name="TextAppearance.KunWorld.CardSubtitleOnDark">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineHeight">18sp</item>
        <item name="android:textColor">@color/text_on_dark_secondary</item>
    </style>

    <!-- Price/Badge Text -->
    <style name="TextAppearance.KunWorld.Badge">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Quick Action Label -->
    <style name="TextAppearance.KunWorld.QuickActionLabel">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Hero Title -->
    <style name="TextAppearance.KunWorld.HeroTitle">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">36sp</item>
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Hero Subtitle -->
    <style name="TextAppearance.KunWorld.HeroSubtitle">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:textColor">@color/text_on_dark_secondary</item>
    </style>

    <!-- Chip Text -->
    <style name="TextAppearance.KunWorld.Chip">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Button Text -->
    <style name="TextAppearance.KunWorld.Button">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Greeting Text (e.g., "Hello, User") -->
    <style name="TextAppearance.KunWorld.Greeting">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Greeting Subtitle -->
    <style name="TextAppearance.KunWorld.GreetingSubtitle">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Istikhara Result Large -->
    <style name="TextAppearance.KunWorld.IstikharaResultLarge">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/istikhara_answer</item>
    </style>

    <!-- Urdu Text -->
    <style name="TextAppearance.KunWorld.Urdu">
        <item name="android:textSize">18sp</item>
        <item name="android:textDirection">rtl</item>
        <item name="android:textAlignment">viewEnd</item>
    </style>

    <!-- Chat Message -->
    <style name="TextAppearance.KunWorld.ChatMessage">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineHeight">22sp</item>
    </style>

    <!-- Empty State Title -->
    <style name="TextAppearance.KunWorld.EmptyStateTitle">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Empty State Description -->
    <style name="TextAppearance.KunWorld.EmptyStateDescription">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
