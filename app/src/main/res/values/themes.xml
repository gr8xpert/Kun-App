<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme - Material 3 -->
    <style name="Theme.Kunworld" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- Error colors -->
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>

        <!-- Outline colors -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Shape system -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.KunWorld.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.KunWorld.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.KunWorld.LargeComponent</item>

        <!-- Typography -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.KunWorld.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.KunWorld.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.KunWorld.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.KunWorld.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.KunWorld.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.KunWorld.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.KunWorld.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.KunWorld.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.KunWorld.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.KunWorld.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.KunWorld.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.KunWorld.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.KunWorld.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.KunWorld.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.KunWorld.LabelSmall</item>

        <!-- Widget styles -->
        <item name="materialCardViewStyle">@style/Widget.KunWorld.CardView</item>
        <item name="chipStyle">@style/Widget.KunWorld.Chip</item>
        <item name="materialButtonStyle">@style/Widget.KunWorld.Button</item>
        <item name="floatingActionButtonStyle">@style/Widget.KunWorld.FAB</item>
        <item name="bottomNavigationStyle">@style/Widget.KunWorld.BottomNavigation</item>
        <item name="textInputStyle">@style/Widget.KunWorld.TextInputLayout</item>
    </style>

    <!-- Theme with ActionBar for activities that need it -->
    <style name="Theme.Kunworld.ActionBar" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.Kunworld.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Kunworld</item>
    </style>

    <!-- Shape Appearances -->
    <style name="ShapeAppearance.KunWorld.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.KunWorld.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.KunWorld.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.KunWorld.ExtraLarge" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Card View Style -->
    <style name="Widget.KunWorld.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.KunWorld.CardView.Flat" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_variant</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.KunWorld.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="android:textColor">@color/chip_text</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textAppearance">@style/TextAppearance.KunWorld.Chip</item>
    </style>

    <style name="Widget.KunWorld.Chip.Choice" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textAppearance">@style/TextAppearance.KunWorld.Chip</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.KunWorld.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAppearance">@style/TextAppearance.KunWorld.Button</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <style name="Widget.KunWorld.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAppearance">@style/TextAppearance.KunWorld.Button</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.KunWorld.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAppearance">@style/TextAppearance.KunWorld.Button</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.KunWorld.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAppearance">@style/TextAppearance.KunWorld.Button</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.KunWorld.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/fab_background</item>
        <item name="tint">@color/fab_icon</item>
        <item name="shapeAppearance">@style/ShapeAppearance.KunWorld.FAB</item>
    </style>

    <style name="Widget.KunWorld.FAB.Large" parent="Widget.Material3.FloatingActionButton.Large.Primary">
        <item name="backgroundTint">@color/fab_background</item>
        <item name="tint">@color/fab_icon</item>
        <item name="shapeAppearance">@style/ShapeAppearance.KunWorld.FAB</item>
    </style>

    <style name="ShapeAppearance.KunWorld.FAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.KunWorld.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/bottom_nav_background</item>
        <item name="itemIconTint">@color/bottom_nav_color_selector</item>
        <item name="itemTextColor">@color/bottom_nav_color_selector</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.KunWorld.BottomNavigation.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="Widget.KunWorld.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_container</item>
    </style>

    <!-- TextInputLayout Style -->
    <style name="Widget.KunWorld.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/text_input_box_stroke</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <style name="Widget.KunWorld.TextInputLayout.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="boxBackgroundColor">@color/surface_variant</item>
    </style>

    <!-- Tab Layout Style -->
    <style name="Widget.KunWorld.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabMode">scrollable</item>
        <item name="tabGravity">start</item>
    </style>

    <style name="Widget.KunWorld.TabLayout.Istikhara" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/istikhara_answer</item>
        <item name="tabSelectedTextColor">@color/white</item>
        <item name="tabTextColor">@color/text_primary</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabMode">scrollable</item>
        <item name="tabBackground">@drawable/istikhara_tab_background</item>
    </style>

    <!-- App Bar Style -->
    <style name="Widget.KunWorld.AppBarLayout" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">@color/surface</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.KunWorld.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/surface</item>
        <item name="titleTextAppearance">@style/TextAppearance.KunWorld.TitleLarge</item>
    </style>

    <!-- Snackbar Style -->
    <style name="Widget.KunWorld.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/on_surface</item>
        <item name="actionTextColorAlpha">1</item>
    </style>

    <!-- Dialog Style -->
    <style name="Theme.KunWorld.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.KunWorld.LargeComponent</item>
        <item name="colorPrimary">@color/primary</item>
    </style>

    <!-- Search View Style -->
    <style name="Widget.KunWorld.SearchView" parent="Widget.Material3.SearchView">
        <item name="android:background">@drawable/search_background</item>
    </style>

    <!-- Progress Indicator Style -->
    <style name="Widget.KunWorld.CircularProgress" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/primary</item>
        <item name="trackColor">@color/primary_container</item>
    </style>

    <style name="Widget.KunWorld.LinearProgress" parent="Widget.Material3.LinearProgressIndicator">
        <item name="indicatorColor">@color/primary</item>
        <item name="trackColor">@color/primary_container</item>
    </style>

    <!-- Circle Image View Style -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
