<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardService"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image with Gradient Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/ivServiceImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/consultancy_business" />

            <!-- Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/card_gradient_overlay" />

            <!-- Title on Image -->
            <TextView
                android:id="@+id/tvServiceTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="16dp"
                android:textAppearance="@style/TextAppearance.KunWorld.TitleLarge"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3"
                tools:text="Business Consultancy" />
        </FrameLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tagline -->
            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.KunWorld.BodyMedium"
                android:textColor="@color/text_secondary"
                tools:text="Transform your business vision into reality" />

            <!-- Feature Chips (First 3) -->
            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/flexFeatures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:flexWrap="wrap"
                app:alignItems="flex_start"
                app:justifyContent="flex_start">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFeature1"
                    style="@style/Widget.KunWorld.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:textSize="11sp"
                    tools:text="Business Mindset" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFeature2"
                    style="@style/Widget.KunWorld.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:textSize="11sp"
                    tools:text="Finance Management" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFeature3"
                    style="@style/Widget.KunWorld.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:textSize="11sp"
                    tools:text="+5 more" />

            </com.google.android.flexbox.FlexboxLayout>

            <!-- Learn More Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLearnMore"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="@string/btn_learn_more"
                android:textAllCaps="false"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
