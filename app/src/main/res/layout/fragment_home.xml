<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.home.HomeFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingBottom="80dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Welcome Section with Logo and Avatar -->
            <RelativeLayout
                android:id="@+id/welcomeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- App Logo on left -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/logoContainer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/white">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="4dp"
                        android:src="@drawable/logo"
                        android:scaleType="fitCenter"
                        android:background="@color/white" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Greeting Text -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/logoContainer"
                    android:layout_toStartOf="@id/ivAvatar"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/text_primary"
                        tools:text="Good Morning" />

                    <TextView
                        android:id="@+id/tvGreetingSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/greeting_subtitle"
                        android:textAppearance="@style/TextAppearance.KunWorld.GreetingSubtitle" />
                </LinearLayout>

                <!-- Avatar on right -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_person"
                    android:background="@color/primary_container"
                    android:padding="12dp"
                    android:elevation="4dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.KunWorld.ExtraLarge" />
            </RelativeLayout>

            <!-- Hero Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/heroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="@drawable/bg_hero_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start Your Journey"
                            android:textAppearance="@style/TextAppearance.KunWorld.HeroTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Discover courses, books &amp; consultancy"
                            android:textAppearance="@style/TextAppearance.KunWorld.HeroSubtitle" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExplore"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginTop="16dp"
                            android:text="Explore Now"
                            android:textColor="@color/on_primary"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="20dp" />
                    </LinearLayout>

                    <!-- Decorative accent -->
                    <View
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="end|bottom"
                        android:layout_marginEnd="-20dp"
                        android:layout_marginBottom="-20dp"
                        android:alpha="0.1"
                        android:background="@drawable/ic_istikhara" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Continue Reading Section (shown when user has progress) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardContinueReading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_variant"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/continue_reading"
                            android:textAppearance="@style/TextAppearance.KunWorld.TitleMedium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvLastRead"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.KunWorld.LabelSmall"
                            android:textColor="@color/text_tertiary"
                            tools:text="Last read 2h ago" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivContinueImage"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.KunWorld.SmallComponent"
                            tools:src="@drawable/ic_courses" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvContinueTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:textAppearance="@style/TextAppearance.KunWorld.BodyLarge"
                                android:textColor="@color/text_primary"
                                tools:text="Personality Development" />

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressContinue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                app:indicatorColor="@color/primary"
                                app:trackColor="@color/primary_container"
                                app:trackCornerRadius="2dp"
                                tools:progress="45" />

                            <TextView
                                android:id="@+id/tvContinueProgress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textAppearance="@style/TextAppearance.KunWorld.LabelSmall"
                                android:textColor="@color/text_secondary"
                                tools:text="45% complete" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnResume"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="@string/resume"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/primary"
                            android:textColor="@color/on_primary"
                            app:cornerRadius="18dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Category Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        style="@style/Widget.KunWorld.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/category_all" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCourses"
                        style="@style/Widget.KunWorld.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_courses" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBooks"
                        style="@style/Widget.KunWorld.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_books" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipConsultancy"
                        style="@style/Widget.KunWorld.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_consultancy" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipVideos"
                        style="@style/Widget.KunWorld.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_videos" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipIstikhara"
                        style="@style/Widget.KunWorld.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_istikhara" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Quick Actions Grid -->
            <LinearLayout
                android:id="@+id/sectionQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="28dp"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_actions"
                    android:textAppearance="@style/TextAppearance.KunWorld.SectionHeader" />

                <GridLayout
                    android:id="@+id/gridQuickActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:columnCount="3"
                    android:rowCount="2"
                    android:alignmentMode="alignBounds">

                    <!-- Videos -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVideos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_action_videos"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_video"
                                app:tint="@color/white"
                                android:contentDescription="@string/videos" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/videos"
                                android:textAppearance="@style/TextAppearance.KunWorld.QuickActionLabel"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Consultancy -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardConsultancy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_action_consultancy"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_consultancy"
                                app:tint="@color/white"
                                android:contentDescription="@string/consultancy" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/consultancy"
                                android:textAppearance="@style/TextAppearance.KunWorld.QuickActionLabel"
                                android:textColor="@color/white"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Courses -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCourses"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_action_courses"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_courses"
                                app:tint="@color/on_primary"
                                android:contentDescription="@string/courses" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/courses"
                                android:textAppearance="@style/TextAppearance.KunWorld.QuickActionLabel"
                                android:textColor="@color/on_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Books -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBooks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_action_books"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_book"
                                app:tint="@color/white"
                                android:contentDescription="@string/books" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/books"
                                android:textAppearance="@style/TextAppearance.KunWorld.QuickActionLabel"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Queries -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQueries"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_action_queries"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_queries"
                                app:tint="@color/white"
                                android:contentDescription="@string/queries" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/queries"
                                android:textAppearance="@style/TextAppearance.KunWorld.QuickActionLabel"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Istikhara -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardIstikhara"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_action_istikhara"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_istikhara"
                                app:tint="@color/white"
                                android:contentDescription="@string/istikhara" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/istikhara"
                                android:textAppearance="@style/TextAppearance.KunWorld.QuickActionLabel"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>
            </LinearLayout>

            <!-- Featured Courses Section -->
            <LinearLayout
                android:id="@+id/sectionFeaturedCourses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_marginTop="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/featured_courses"
                        android:textAppearance="@style/TextAppearance.KunWorld.SectionHeader" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSeeAllCourses"
                        style="@style/Widget.KunWorld.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:minHeight="0dp"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Shimmer loading placeholder -->
                <include
                    android:id="@+id/shimmerCourses"
                    layout="@layout/shimmer_home_courses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFeaturedCourses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:paddingHorizontal="14dp"
                    android:paddingBottom="8dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_course_card" />
            </LinearLayout>

            <!-- Top Consultancies Section -->
            <LinearLayout
                android:id="@+id/sectionPopularConsultants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/popular_consultants"
                        android:textAppearance="@style/TextAppearance.KunWorld.SectionHeader" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSeeAllConsultants"
                        style="@style/Widget.KunWorld.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:minHeight="0dp"
                        android:padding="8dp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPopularConsultants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:paddingHorizontal="14dp"
                    android:paddingBottom="8dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_consultant_card" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
